{
  "name": "neuralsentinel",
  "version": "1.0.0",
  "description": "NeuralSentinel - ML Model Auditing Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "author": "Neural Sentinel",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.neuralsentinel.mlauditor",
    "artifactName": "NeuralSentinel-${version}-Setup.${ext}",
    "productName": "NeuralSentinel",
    "copyright": "Copyright © 2026 Neural Sentinel",
    "directories": {
      "shortcutName": "NeuralSentinel",
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**/*",
      "backend/**/*",
      "data/**/*",
      "!backend/venv/**/*",
      "!backend/__pycache__/**/*",
      "!backend/**/*.pyc"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!venv/**/*",
          "!__pycache__/**/*",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}